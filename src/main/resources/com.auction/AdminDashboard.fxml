<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.controller.AdminDashboardController"
            stylesheets="@style.css"
            styleClass="root"
            style="-fx-padding: 30; -fx-min-width: 850; -fx-min-height: 600;">
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 0 0 20 0;">
            <Label text="QUẢN TRỊ HỆ THỐNG" styleClass="header-label" style="-fx-font-size: 24px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Làm mới"      onAction="#handleRefresh" styleClass="button-secondary" prefHeight="35"/>
            <Button text="← Quay lại" onAction="#handleBack" styleClass="button-secondary" prefHeight="35"/>
        </HBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" styleClass="card">
            <Tab text="Tất cả phiên đấu giá">
                <VBox>
                    <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="colAuctionId"     text="ID"          prefWidth="90"/>
                            <TableColumn fx:id="colAuctionName"   text="Tên Sản Phẩm" prefWidth="170"/>
                            <TableColumn fx:id="colAuctionPrice"  text="Giá Hiện Tại" prefWidth="130"/>
                            <TableColumn fx:id="colAuctionStatus" text="Trạng Thái"  prefWidth="110"/>
                            <TableColumn fx:id="colAuctionSeller" text="ID Người Bán" prefWidth="120"/>
                            <TableColumn fx:id="colAuctionEnd"    text="Thời Gian Kết Thúc" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>
            <Tab text="Thống kê">
                <VBox spacing="15" style="-fx-padding: 30;">
                    <Label text="Báo Cáo Thống Kê" styleClass="title-label" style="-fx-font-size: 20px;"/>
                    <Separator/>
                    <Label fx:id="statTotal"    styleClass="title-label" style="-fx-font-size: 16px;"/>
                    <Label fx:id="statRunning"  styleClass="title-label" style="-fx-font-size: 16px; -fx-text-fill: #3b82f6;"/>
                    <Label fx:id="statFinished" styleClass="title-label" style="-fx-font-size: 16px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="statCanceled" styleClass="title-label" style="-fx-font-size: 16px; -fx-text-fill: #ef4444;"/>
                </VBox>
            </Tab>
        </TabPane>
    </center>
    <bottom>
        <HBox style="-fx-padding: 20 0 0 0;">
            <Button text="ĐÓNG PHIÊN ĐÃ CHỌN" onAction="#handleForceClose" styleClass="button-danger" prefHeight="35"/>
        </HBox>
    </bottom>
</BorderPane>
