<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controller.BiddingController"
      stylesheets="@style.css"
      styleClass="root"
      style="-fx-padding: 15; -fx-min-width: 850; -fx-pref-height: 600;">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 10 0;">
            <Button text="← Quay lại" onAction="#handleBack" styleClass="button-secondary" prefHeight="30"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="countdownLabel" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
            <Region prefWidth="10"/>
            <Label fx:id="clockLabel" style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="15" HBox.hgrow="ALWAYS">
            <!-- LEFT: Info + Bidding -->
            <VBox spacing="12" HBox.hgrow="ALWAYS" style="-fx-min-width: 380;">
                <!-- Product Info Card -->
                <VBox spacing="8" styleClass="card">
                    <Label fx:id="titleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e40af;"/>
                    <Label fx:id="typeLabel" style="-fx-font-size: 13px; -fx-text-fill: #6b7280;"/>
                    <Label fx:id="statusLabel" style="-fx-font-size: 13px;"/>
                    <Separator/>
                    <GridPane hgap="15" vgap="8">
                        <Label text="Giá hiện tại:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-size: 13px;"/>
                        <Label fx:id="currentPriceLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"
                               style="-fx-font-weight: bold; -fx-text-fill: #ef4444; -fx-font-size: 16px;"/>
                        <Label text="Người dẫn đầu:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-size: 13px;"/>
                        <Label fx:id="leadingBidderLabel" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                        <Label text="Kết thúc lúc:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-size: 13px;"/>
                        <Label fx:id="endTimeLabel" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    </GridPane>
                </VBox>

                <!-- Bid Input -->
                <VBox spacing="8" styleClass="card">
                    <Label text="Đặt Giá" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <TextField fx:id="bidAmountField" promptText="Nhập giá đặt..." prefHeight="35" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="placeBidBtn" text="ĐẶT GIÁ" onAction="#handlePlaceBid"
                                styleClass="button" prefHeight="35" prefWidth="100"/>
                    </HBox>
                    <Label fx:id="resultLabel" wrapText="true"/>
                </VBox>

                <!-- Auto-Bid -->
                <VBox spacing="8" styleClass="card">
                    <Label text="⚡ Auto-Bid" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Tối đa:" prefWidth="55" style="-fx-font-size: 12px;"/>
                        <TextField fx:id="autoBidMaxField" promptText="VD: 5000000" prefHeight="30" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Bước:" prefWidth="55" style="-fx-font-size: 12px;"/>
                        <TextField fx:id="autoBidIncrementField" promptText="VD: 100000" prefHeight="30" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER">
                        <Button fx:id="registerAutoBidBtn" text="Bật Auto-Bid" onAction="#handleRegisterAutoBid"
                                styleClass="button" prefHeight="30"/>
                        <Button fx:id="cancelAutoBidBtn" text="Tắt" onAction="#handleCancelAutoBid"
                                styleClass="button-danger" prefHeight="30"/>
                    </HBox>
                    <Label fx:id="autoBidStatusLabel" wrapText="true" style="-fx-font-size: 12px;"/>
                </VBox>
            </VBox>

            <!-- RIGHT: Chart -->
            <VBox styleClass="card" HBox.hgrow="ALWAYS" style="-fx-min-width: 350;">
                <Label text="📊 Lịch Sử Giá" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                <LineChart fx:id="bidHistoryChart" VBox.vgrow="ALWAYS"
                           animated="false" createSymbols="true"
                           legendVisible="false" style="-fx-font-size: 11px;">
                    <xAxis>
                        <CategoryAxis label="Thời gian" fx:id="chartXAxis"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Giá (đ)" fx:id="chartYAxis" forceZeroInRange="false"/>
                    </yAxis>
                </LineChart>
                <!-- Winner notification -->
                <VBox fx:id="winnerBox" visible="false" managed="false" alignment="CENTER" spacing="5"
                      style="-fx-background-color: #fef3c7; -fx-padding: 10; -fx-background-radius: 5;">
                    <Label fx:id="winnerLabel" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #b45309;" wrapText="true"/>
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>