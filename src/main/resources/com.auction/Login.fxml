<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controller.LoginController"
      stylesheets="@style.css"
      styleClass="root"
      style="-fx-padding: 60; -fx-min-width: 400; -fx-min-height: 500;">

    <VBox alignment="CENTER" spacing="20" styleClass="card" maxWidth="350">
        <Label text="HỆ THỐNG ĐẤU GIÁ" styleClass="header-label"/>
        
        <VBox spacing="10">
            <Label text="Tên đăng nhập" styleClass="title-label" style="-fx-font-size: 14px;"/>
            <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập..." styleClass="text-field" prefHeight="40"/>
        </VBox>
        
        <VBox spacing="10">
            <Label text="Mật khẩu" styleClass="title-label" style="-fx-font-size: 14px;"/>
            <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu..." styleClass="password-field" prefHeight="40"/>
        </VBox>

        <Button text="ĐĂNG NHẬP" onAction="#handleLogin"
                styleClass="button" prefWidth="300" prefHeight="40" style="-fx-margin-top: 10;"/>
        <Button text="Đăng ký tài khoản mới" onAction="#goToRegister"
                styleClass="button-secondary" prefWidth="300" prefHeight="40"/>

        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" textAlignment="CENTER"/>
    </VBox>
</VBox>