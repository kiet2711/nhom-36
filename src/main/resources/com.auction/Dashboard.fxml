<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.controller.DashboardController"
            stylesheets="@style.css"
            styleClass="root"
            style="-fx-padding: 30; -fx-min-width: 800; -fx-min-height: 600;">

      <top>
            <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 0 0 20 0;">
                  <Label text="Đấu Giá" styleClass="header-label" style="-fx-font-size: 28px; -fx-text-fill: #2563eb;"/>
                  <Region prefWidth="30"/>
                  <Label fx:id="welcomeLabel" styleClass="title-label" style="-fx-font-size: 16px;"/>
                  
                  <Region HBox.hgrow="ALWAYS"/>
                  
                  <Button fx:id="createAuctionBtn" text="+ Tạo Phiên Mới" 
                          onAction="#handleCreateAuction" styleClass="button" prefHeight="35"/>
                  <CheckBox fx:id="filterMyBidsCheck" text="Chỉ hiển thị phiên đã tham gia" 
                            onAction="#handleRefresh" visible="false" managed="false"/>
                  <Button text="Làm mới" onAction="#handleRefresh" styleClass="button-secondary" prefHeight="35"/>
                  <Button text="Đăng xuất" onAction="#handleLogout" styleClass="button-danger" prefHeight="35"/>
                  <Button fx:id="adminBtn" text="Quản trị"
                          onAction="#handleAdmin" visible="false" styleClass="button" prefHeight="35"/>
            </HBox>
      </top>

      <center>
            <VBox styleClass="card">
                <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                      <columns>
                            <TableColumn fx:id="colName"   text="Tên Sản Phẩm" prefWidth="200"/>
                            <TableColumn fx:id="colType"   text="Phân Loại"    prefWidth="120"/>
                            <TableColumn fx:id="colPrice"  text="Giá Hiện Tại" prefWidth="150"/>
                            <TableColumn fx:id="colStatus" text="Trạng Thái"   prefWidth="120"/>
                            <TableColumn fx:id="colEnd"    text="Thời Gian Kết Thúc" prefWidth="150"/>
                      </columns>
                </TableView>
            </VBox>
      </center>

      <bottom>
            <HBox style="-fx-padding: 20 0 0 0;" alignment="CENTER">
                  <Button text="THAM GIA ĐẤU GIÁ" onAction="#handleJoinAuction"
                          styleClass="button" style="-fx-font-size: 16px; -fx-padding: 12 30;"/>
            </HBox>
      </bottom>
</BorderPane>