<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox spacing="15" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controller.RegisterController"
      stylesheets="@style.css"
      styleClass="root"
      style="-fx-padding: 60; -fx-min-width: 400; -fx-min-height: 550;">

    <VBox alignment="CENTER" spacing="20" styleClass="card" maxWidth="350">
        <Label text="ĐĂNG KÝ TÀI KHOẢN" styleClass="header-label"/>
        
        <VBox spacing="10">
            <Label text="Tên đăng nhập" styleClass="title-label" style="-fx-font-size: 14px;"/>
            <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập..." styleClass="text-field" prefHeight="40"/>
        </VBox>
        
        <VBox spacing="10">
            <Label text="Mật khẩu" styleClass="title-label" style="-fx-font-size: 14px;"/>
            <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu..." styleClass="password-field" prefHeight="40"/>
        </VBox>
        
        <VBox spacing="10">
            <Label text="Vai trò" styleClass="title-label" style="-fx-font-size: 14px;"/>
            <ComboBox fx:id="roleComboBox" promptText="Chọn vai trò của bạn..." prefHeight="40" prefWidth="300" styleClass="text-field"/>
        </VBox>

        <Button text="ĐĂNG KÝ" onAction="#handleRegister"
                styleClass="button" prefWidth="300" prefHeight="40" style="-fx-margin-top: 10;"/>
        <Button text="Quay lại Đăng nhập" onAction="#goToLogin"
                styleClass="button-secondary" prefWidth="300" prefHeight="40"/>

        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" textAlignment="CENTER"/>
    </VBox>
</VBox>