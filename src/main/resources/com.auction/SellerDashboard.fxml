<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.controller.SellerDashboardController"
            stylesheets="@style.css"
            styleClass="root"
            style="-fx-padding: 30; -fx-min-width: 800; -fx-min-height: 600;">
    <top>
        <HBox spacing="15" alignment="CENTER_LEFT"
              style="-fx-padding: 0 0 20 0;">
            <Label text="Quản Lý Sản Phẩm Đấu Giá"
                   styleClass="header-label" style="-fx-font-size: 24px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Tạo Phiên Mới" onAction="#handleCreate" styleClass="button" prefHeight="35"/>
            <Button text="Làm mới"       onAction="#handleRefresh" styleClass="button-secondary" prefHeight="35"/>
            <Button text="← Quay lại"   onAction="#handleBack" styleClass="button-secondary" prefHeight="35"/>
        </HBox>
    </top>

    <center>
        <VBox styleClass="card">
            <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colName"    text="Tên Sản Phẩm"  prefWidth="180"/>
                    <TableColumn fx:id="colType"    text="Phân Loại"     prefWidth="100"/>
                    <TableColumn fx:id="colPrice"   text="Giá Hiện Tại"  prefWidth="130"/>
                    <TableColumn fx:id="colStatus"  text="Trạng Thái"    prefWidth="110"/>
                    <TableColumn fx:id="colLeader"  text="Người Dẫn Đầu" prefWidth="130"/>
                    <TableColumn fx:id="colEnd"     text="Thời Gian Kết Thúc" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="15" style="-fx-padding: 20 0 0 0;" alignment="CENTER_LEFT">
            <Button text="SỬA PHIÊN ĐÃ CHỌN" onAction="#handleEdit"
                    styleClass="button" prefHeight="35"/>
            <Button text="HUỶ PHIÊN ĐÃ CHỌN" onAction="#handleCancel"
                    styleClass="button-danger" prefHeight="35"/>
            <Label fx:id="statusLabel" styleClass="title-label" style="-fx-padding: 4 0 0 10;"/>
        </HBox>
    </bottom>
</BorderPane>