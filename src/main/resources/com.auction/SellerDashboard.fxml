<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.auction.controller.SellerDashboardController"
            style="-fx-padding: 20; -fx-min-width: 700; -fx-min-height: 500;">
    <top>
        <HBox spacing="16" alignment="CENTER_LEFT"
              style="-fx-padding: 0 0 16 0;">
            <Label text="QUẢN LÝ PHIÊN ĐẤU GIÁ CỦA BẠN"
                   style="-fx-font-size: 16; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Tạo phiên mới" onAction="#handleCreate"/>
            <Button text="Làm mới"       onAction="#handleRefresh"/>
            <Button text="← Quay lại"   onAction="#handleBack"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="auctionTable">
            <columns>
                <TableColumn fx:id="colName"    text="Sản phẩm"     prefWidth="160"/>
                <TableColumn fx:id="colType"    text="Loại"         prefWidth="100"/>
                <TableColumn fx:id="colPrice"   text="Giá hiện tại" prefWidth="120"/>
                <TableColumn fx:id="colStatus"  text="Trạng thái"   prefWidth="100"/>
                <TableColumn fx:id="colLeader"  text="Người dẫn đầu" prefWidth="130"/>
                <TableColumn fx:id="colEnd"     text="Kết thúc"     prefWidth="140"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="10" style="-fx-padding: 12 0 0 0;">
            <Button text="Huỷ phiên đã chọn" onAction="#handleCancel"
                    style="-fx-text-fill: red;"/>
            <Label fx:id="statusLabel" style="-fx-padding: 4 0 0 10;"/>
        </HBox>
    </bottom>
</BorderPane>