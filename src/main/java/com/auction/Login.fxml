<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="12" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.controller.LoginController"
      style="-fx-padding: 40; -fx-min-width: 320;">

    <Label text="HỆ THỐNG ĐẤU GIÁ" style="-fx-font-size: 20; -fx-font-weight: bold;"/>

    <TextField fx:id="usernameField" promptText="Tên đăng nhập"/>
    <PasswordField fx:id="passwordField" promptText="Mật khẩu"/>

    <Button text="Đăng nhập" onAction="#handleLogin"
            style="-fx-min-width: 200;"/>
    <Button text="Chưa có tài khoản? Đăng ký" onAction="#goToRegister"
            style="-fx-min-width: 200;"/>

    <Label fx:id="errorLabel" style="-fx-text-fill: red;"/>
</VBox>